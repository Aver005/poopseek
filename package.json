{
  "name": "poopseek",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "check": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cloc": "cloc --exclude-dir=\"node_modules,build,.git\" .",

    "build:windows": "bun run scripts/build/build-exe.ts",
    "build:macos": "bash scripts/build/build-macos.sh",
    "build:plugin": "bun run plugins/figma/build.ts",
    "build:all": "bun run build:windows && bun run build:plugin",

    "compile":     "bun run build:windows",
    "compile:mac": "bun run build:macos"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/terminal-kit": "^2.5.7",
    "@vitest/coverage-v8": "^4.1.5",
    "cloc": "^2.6.0-cloc",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.34.0",
    "terminal-kit": "^3.1.2"
  }
}
